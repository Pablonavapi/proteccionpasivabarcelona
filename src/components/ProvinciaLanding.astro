---
// =====================================================================
// PLANTILLA de landing por provincia (Girona, Tarragona, Lleida...).
// Mismo diseño, imágenes y datos de contacto que la home; el CONTENIDO
// (texto) es único por provincia y llega en la prop `data` (un JSON).
// =====================================================================
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import StickyMobile from './StickyMobile.astro';
import PresupuestoForm from './PresupuestoForm.astro';
import ContactButtons from './ContactButtons.astro';
import { EMPRESA } from '../config.mjs';
import fs from 'node:fs';
import path from 'node:path';

export interface Props { data: any }
const { data } = Astro.props;

const tel = `tel:+${EMPRESA.telefonoLink}`;
const mail = `mailto:${EMPRESA.email}`;

// --- Imágenes (las mismas que la home; se muestran solo si existen) ---
const IMG = {
  mortero: '/img/ignifugacion-mortero.jpg',
  intumescente: '/img/ignifugacion-intumescente.jpg',
  estructura: '/img/estructura-metalica.jpg',
  furgoneta: '/img/furgoneta-grupo-ignifugo.jpg',
};
const publicHas = (rel) => { try { return fs.existsSync(path.join(process.cwd(), 'public', rel)); } catch { return false; } };
const img = (rel) => (publicHas(rel) ? rel : null);
const heroImg = img(IMG.mortero);
const furgoImg = img(IMG.furgoneta);
const casoImgs = [img(IMG.estructura), img(IMG.intumescente), img(IMG.mortero)];
const heroStyle = heroImg
  ? `background-image: linear-gradient(100deg, rgba(12,26,46,0.92) 0%, rgba(12,26,46,0.72) 44%, rgba(12,26,46,0.32) 100%), url('${heroImg}');`
  : undefined;

// --- Iconos (mismos que la home): 8 servicios en orden fijo + 6 sectores ---
const SERV_ICONS = [
  '<path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/>',
  '<path d="M2 20h20"/><path d="M4 20V8l8-4 8 4v12"/><path d="m4 12 8 4 8-4"/>',
  '<path d="M17.5 19a4.5 4.5 0 0 0 0-9h-.7A6 6 0 1 0 6 15"/><path d="M8 19h9"/><path d="M6 15v4"/>',
  '<path d="M12 22V8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M12 8a4 4 0 0 0 4-4 4 4 0 0 0-8 0 4 4 0 0 0 4 4z"/>',
  '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>',
  '<rect x="3" y="3" width="7" height="18" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/>',
  '<rect x="3" y="4" width="18" height="16" rx="1"/><path d="M3 10h18"/><path d="M3 15h18"/><path d="M9 4v16"/>',
  '<path d="M2 20h20"/><rect x="4" y="9" width="16" height="6"/><path d="M4 9V6h16v3"/><path d="M9 9v6"/><path d="M15 9v6"/>',
];
const SECT_ICONS = [
  '<path d="M3 21V8l6-4v4l6-4v4l6-4v13"/><path d="M3 21h18"/><path d="M8 21v-4"/><path d="M14 21v-4"/>',
  '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>',
  '<path d="M2 22h20"/><path d="M4 22V6l8-4 8 4v16"/><path d="M9 22v-5h6v5"/>',
  '<path d="M3 9 4 4h16l1 5"/><path d="M4 9v11h16V9"/><path d="M9 20v-6h6v6"/>',
  '<path d="M12 3v18"/><path d="M8 3v6a4 4 0 0 0 8 0V3"/><path d="M19 3v18"/>',
  '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>',
];
const CHECK = '<path d="M20 6 9 17l-5-5"/>';

// --- SEO / Schema.org de la página ---
const pageUrl = `${EMPRESA.dominio}/${data.slug}/`;
const ogImage = heroImg ? `${EMPRESA.dominio}${IMG.mortero}` : undefined;
const jsonLd = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${EMPRESA.dominio}/` },
      { '@type': 'ListItem', position: 2, name: `Ignifugación en ${data.provincia}`, item: pageUrl },
    ],
  },
  {
    '@type': 'Service',
    name: `Ignifugación y protección pasiva contra incendios en ${data.provincia}`,
    serviceType: 'Ignifugación de estructura metálica',
    provider: { '@id': `${EMPRESA.dominio}/#empresa` },
    areaServed: { '@type': 'AdministrativeArea', name: `Provincia de ${data.provincia}` },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: `Servicios de ignifugación en ${data.provincia}`,
      itemListElement: data.servicios.items.map((s) => ({ '@type': 'Offer', itemOffered: { '@type': 'Service', name: s.t } })),
    },
  },
  {
    '@type': 'FAQPage',
    mainEntity: data.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<Layout title={data.meta.title} description={data.meta.desc} image={ogImage} jsonLd={jsonLd}>
  <Header />

  <div class="ig-wrap">

    <!-- HERO -->
    <section class="ig-hero" style={heroStyle}>
      <div class="ig-hero-inner">
        <div class="ig-hero-text">
          <span class="ig-eyebrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5l-8-3z"/></svg>
            Protección pasiva contra incendios · {data.provincia} y provincia
          </span>
          <h1 class="ig-h1">{data.hero.h1a} <em>{data.hero.h1em}</em></h1>
          <p class="ig-hero-sub">{data.hero.sub}</p>
          <ul class="ig-hero-promesas">
            {data.hero.promesas.map((p) => (
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <span><strong>{p.s}</strong> {p.t}</span></li>
            ))}
          </ul>
          <ContactButtons />
          <div class="ig-hero-badges">
            <span class="ig-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg> Empresa habilitada PCI</span>
            <span class="ig-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5l-8-3z"/></svg> Seguro RC {EMPRESA.seguroRC}</span>
            <span class="ig-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M8.21 13.89 7 22l5-3 5 3-1.21-8.11"/></svg> Ensayos en laboratorio ENAC</span>
          </div>
        </div>
      </div>
    </section>

    <!-- EMPRESA / FURGONETA -->
    {furgoImg && (
      <section class="ig-sec ig-sec--gris" id="empresa">
        <div class="ig-inner">
          <div class="ig-furgo-grid">
            <figure class="ig-furgo-img">
              <img src={furgoImg} alt={`Furgoneta de Grupo Ignífugo, empresa de ignifugación en ${data.provincia}, con plataforma elevadora`} loading="lazy" decoding="async" width="1200" height="900" />
            </figure>
            <div class="ig-furgo-txt">
              <span class="ig-kicker">{data.empresa.kicker}</span>
              <h2 class="ig-h2">{data.empresa.h2}</h2>
              <p class="ig-lead" set:html={data.empresa.text}></p>
              <ul class="ig-cert-list">
                {data.empresa.bullets.map((b) => (
                  <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={CHECK} /></svg><span><strong>{b.s}</strong> {b.t}</span></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- CTA BAND -->
    <div class="ig-cta-band ig-bleed">
      <div class="ig-cta-band-inner">
        <div class="ig-cta-band-txt">
          <h2>¿Necesitas ignifugar una obra en {data.provincia}? Te llamamos hoy mismo</h2>
          <p>Envíanos los planos o las mediciones y te damos precio cerrado en 24-48 h.</p>
        </div>
        <div class="ig-cta-band-side"><ContactButtons /></div>
      </div>
    </div>

    <!-- SERVICIOS -->
    <section class="ig-sec ig-sec--blanco" id="servicios">
      <div class="ig-inner">
        <div class="ig-sec-head ig-sec-head--center">
          <span class="ig-kicker">Servicios</span>
          <h2 class="ig-h2">{data.servicios.h2}</h2>
          <p class="ig-lead">{data.servicios.intro}</p>
        </div>
        <div class="ig-serv-grid">
          {data.servicios.items.map((s, i) => (
            <article class="ig-serv">
              <span class="ig-serv-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={SERV_ICONS[i]} /></svg></span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
              <span class="ig-serv-rf"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg> {s.rf}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PRECIOS -->
    <section class="ig-sec ig-sec--gris" id="precios">
      <div class="ig-inner">
        <div class="ig-sec-head">
          <span class="ig-kicker">Precios orientativos</span>
          <h2 class="ig-h2">¿Cuánto cuesta ignifugar una estructura metálica en {data.provincia}?</h2>
          <p class="ig-lead">{data.precio.intro}</p>
        </div>
        <div class="ig-precio-grid">
          <div>
            <div class="ig-table-wrap">
              <table class="ig-precio-table">
                <thead><tr><th>Servicio</th><th>Precio orientativo</th></tr></thead>
                <tbody>
                  <tr><td class="ig-precio-serv">Pintura intumescente<small>Estructura metálica vista, según R y masividad</small></td><td class="ig-precio-val">12 – 35 €/m²</td></tr>
                  <tr><td class="ig-precio-serv">Mortero ignífugo proyectado<small>Perlita-vermiculita o lana de roca</small></td><td class="ig-precio-val">9 – 22 €/m²</td></tr>
                  <tr><td class="ig-precio-serv">Sellado cortafuegos<small>Pasos de instalaciones, por penetración</small></td><td class="ig-precio-val">desde 30 €/ud</td></tr>
                  <tr><td class="ig-precio-serv">Sectorización con placa rígida<small>Muros y tabiques EI</small></td><td class="ig-precio-val">45 – 95 €/m²</td></tr>
                </tbody>
              </table>
            </div>
            <p class="ig-precio-nota" set:html={data.precio.nota}></p>
          </div>
          <div>
            <h3 class="ig-h2" style="font-size:22px;margin-bottom:20px;">Qué determina el precio</h3>
            <ul class="ig-factores">
              {data.precio.factores.map((f, i) => (
                <li class="ig-factor"><span class="ig-factor-n">{i + 1}</span><div><h4>{f.h}</h4><p>{f.d}</p></div></li>
              ))}
            </ul>
            <div class="ig-hero-cta" style="margin-top:26px;">
              <a href="#presupuesto" class="ig-btn ig-btn-fuego">Pásanos m² y R y te damos precio hoy</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROCESO -->
    <section class="ig-sec ig-sec--navy ig-bleed" id="proceso">
      <div class="ig-inner">
        <div class="ig-sec-head">
          <span class="ig-kicker">Cómo trabajamos</span>
          <h2 class="ig-h2">De la visita a obra al certificado, en 5 pasos</h2>
          <p class="ig-lead">{data.proceso.intro}</p>
        </div>
        <div class="ig-pasos">
          {data.proceso.pasos.map((p, i) => (
            <div class="ig-paso"><span class="ig-paso-n">{String(i + 1).padStart(2, '0')}</span><h3>{p.h}</h3><p>{p.d}</p></div>
          ))}
        </div>
        <div class="ig-paso-cta">
          <a href="#presupuesto" class="ig-btn ig-btn-fuego">Pide presupuesto</a>
        </div>
        <div class="ig-paso-contact"><ContactButtons /></div>
      </div>
    </section>

    <!-- NORMATIVA -->
    <section class="ig-sec ig-sec--navy ig-bleed" id="normativa" style="background-image:radial-gradient(circle at 88% 100%, rgba(255,138,91,0.13), transparent 45%);">
      <div class="ig-inner">
        <div class="ig-sec-head">
          <span class="ig-kicker">Normativa</span>
          <h2 class="ig-h2">Cuándo es obligatorio ignifugar en {data.provincia}</h2>
          <p class="ig-lead">{data.normativa.intro}</p>
        </div>
        <div class="ig-norma-grid">
          {data.normativa.cards.map((c) => (
            <div class="ig-norma">
              <span class="ig-norma-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>
              <h3>{c.h}</h3>
              <p set:html={c.d}></p>
              <span class="ig-tag">{c.tag}</span>
            </div>
          ))}
        </div>
        <div class="ig-table-wrap">
          <table class="ig-rf-table">
            <thead><tr><th>Uso / tipo de edificio</th><th>Resistencia al fuego habitual</th></tr></thead>
            <tbody>
              <tr><td><strong>Vivienda unifamiliar</strong></td><td class="ig-rf-val">R30</td></tr>
              <tr><td><strong>Residencial / administrativo / docente</strong> (≤15 m)</td><td class="ig-rf-val">R60</td></tr>
              <tr><td><strong>Comercial / pública concurrencia / hospitalario</strong> (≤15 m)</td><td class="ig-rf-val">R90</td></tr>
              <tr><td><strong>Aparcamiento</strong></td><td class="ig-rf-val">R90 – R120</td></tr>
              <tr><td><strong>Plantas de sótano</strong></td><td class="ig-rf-val">R120</td></tr>
              <tr><td><strong>Nave industrial</strong> (según riesgo intrínseco y tipo)</td><td class="ig-rf-val">R30 – R180</td></tr>
            </tbody>
          </table>
        </div>
        <p class="ig-lead" style="font-size:13.5px;margin-top:14px;color:#A9BAD0;">{data.normativa.nota}</p>
      </div>
    </section>

    <!-- CERTIFICADO -->
    <section class="ig-sec ig-sec--blanco" id="certificado">
      <div class="ig-inner">
        <div class="ig-cert-grid">
          <div>
            <span class="ig-kicker">{data.certificado.kicker}</span>
            <h2 class="ig-h2">{data.certificado.h2}</h2>
            <p class="ig-lead">{data.certificado.text}</p>
            <ul class="ig-cert-list">
              {data.certificado.bullets.map((b) => (
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={CHECK} /></svg><span><strong>{b.s}</strong> {b.t}</span></li>
              ))}
            </ul>
          </div>
          <div class="ig-cert-doc" aria-hidden="true">
            <div class="ig-cert-doc-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              <div><h3>Certificado de aplicación</h3><span>Protección pasiva contra incendios</span></div>
            </div>
            <div class="ig-cert-doc-body">
              <div class="ig-cert-row"><span>Sistema aplicado</span><strong>Pintura intumescente</strong></div>
              <div class="ig-cert-row"><span>Elemento protegido</span><strong>Estructura metálica</strong></div>
              <div class="ig-cert-row"><span>Resistencia obtenida</span><strong>R90</strong></div>
              <div class="ig-cert-row"><span>Espesor medio (DFT)</span><strong>1.150 µm</strong></div>
              <div class="ig-cert-row"><span>Ensayo de referencia</span><strong>UNE-EN 13381-8</strong></div>
              <div class="ig-cert-row"><span>Norma de clasificación</span><strong>UNE-EN 13501-2</strong></div>
              <span class="ig-cert-seal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M8.21 13.89 7 22l5-3 5 3-1.21-8.11"/></svg> Firmado y visado por técnico competente</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTORES -->
    <section class="ig-sec ig-sec--gris" id="sectores">
      <div class="ig-inner">
        <div class="ig-sec-head ig-sec-head--center">
          <span class="ig-kicker">Dónde trabajamos</span>
          <h2 class="ig-h2">{data.sectores.h2}</h2>
          <p class="ig-lead">{data.sectores.intro}</p>
        </div>
        <div class="ig-sector-grid">
          {data.sectores.items.map((s, i) => (
            <article class="ig-sector">
              <span class="ig-sector-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={SECT_ICONS[i % SECT_ICONS.length]} /></svg></span>
              <div>
                <h3>{s.t}</h3>
                <p>{s.d}</p>
                <span class="ig-sector-rf">{s.rf}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- OBRAS -->
    <section class="ig-sec ig-sec--navy ig-bleed" id="obras">
      <div class="ig-inner">
        <div class="ig-sec-head ig-sec-head--center">
          <span class="ig-kicker">Obras realizadas</span>
          <h2 class="ig-h2">{data.obras.h2}</h2>
          <p class="ig-lead">{data.obras.intro}</p>
        </div>
        <div class="ig-stats" style="margin-bottom:36px;">
          {data.obras.stats.map((st) => (
            <div class="ig-stat"><span class="ig-stat-n">{st.n}</span><span class="ig-stat-lbl">{st.l}</span></div>
          ))}
        </div>
        <div class="ig-casos-grid">
          {data.obras.casos.map((c, i) => (
            <article class="ig-caso">
              <div class="ig-caso-img">
                <span class="ig-caso-rf">{c.rf}</span>
                {casoImgs[i]
                  ? <img src={casoImgs[i]} alt={`${c.t} — ignifugación en ${data.provincia}`} loading="lazy" decoding="async" width="600" height="400" />
                  : <span class="ig-caso-img-ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></span>}
              </div>
              <div class="ig-caso-body">
                <span class="ig-caso-sector">{c.sector}</span>
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <div class="ig-caso-meta">
                  <div><strong>{c.m2}</strong>superficie</div>
                  <div><strong>{c.metodo}</strong>método</div>
                  <div><strong>{c.plazo}</strong>ejecución</div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- POR QUÉ ELEGIRNOS -->
    <section class="ig-sec ig-sec--blanco">
      <div class="ig-inner">
        <div class="ig-sec-head ig-sec-head--center">
          <span class="ig-kicker">Por qué elegirnos</span>
          <h2 class="ig-h2">{data.why.h2}</h2>
          <p class="ig-lead">{data.why.intro}</p>
        </div>
        <div class="ig-why-grid">
          {data.why.items.map((w, i) => (
            <div class="ig-why">
              <span class="ig-why-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={SECT_ICONS[i]} /></svg></span>
              <h3>{w.h}</h3>
              <p set:html={w.d}></p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FORMULARIO -->
    <section class="ig-sec ig-sec--gris" id="presupuesto">
      <div class="ig-inner">
        <div class="ig-formsec-grid">
          <div class="ig-formsec-info">
            <span class="ig-kicker">Presupuesto sin compromiso</span>
            <h2 class="ig-h2">{data.form.h2}</h2>
            <p class="ig-lead">{data.form.intro}</p>
            <ul class="ig-contact-list">
              <a href={mail} class="ig-contact-row ig-contact-row--primary">
                <span class="ig-contact-ico mail-p"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></span>
                <span class="ig-contact-txt"><span>Escríbenos</span><strong class="ig-contact-val">{EMPRESA.email}</strong></span>
              </a>
              <a href={tel} class="ig-contact-row">
                <span class="ig-contact-ico tel"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                <span class="ig-contact-txt"><span>Llámanos</span><strong class="ig-contact-val">{EMPRESA.telefonoMostrar}</strong></span>
              </a>
            </ul>
          </div>
          <div class="ig-formsec-form">
            <PresupuestoForm anchorId="form-principal" origen={`Landing ${data.provincia}`} />
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="ig-sec ig-sec--blanco" id="faq">
      <div class="ig-inner ig-inner--medio">
        <div class="ig-sec-head ig-sec-head--center">
          <span class="ig-kicker">Preguntas frecuentes</span>
          <h2 class="ig-h2">Ignifugación en {data.provincia}: preguntas frecuentes</h2>
        </div>
        <div class="ig-faq-list">
          {data.faq.map((f) => (
            <details class="ig-faq-item">
              <summary>
                <h3 class="ig-faq-q">{f.q}</h3>
                <svg class="ig-faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="ig-faq-a"><p>{f.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <div class="ig-cta-band ig-bleed">
      <div class="ig-cta-band-inner">
        <div class="ig-cta-band-txt">
          <h2>{data.ctaFinal.h2}</h2>
          <p>{data.ctaFinal.p}</p>
        </div>
        <div class="ig-cta-band-side">
          <ContactButtons />
          <a href="#presupuesto" class="ig-btn ig-btn-white ig-btn-lg ig-cta-band-form">Rellenar formulario</a>
        </div>
      </div>
    </div>

  </div>

  <Footer />
  <StickyMobile />
</Layout>
