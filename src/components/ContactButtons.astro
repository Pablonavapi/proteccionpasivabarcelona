---
// Botones de contacto en formato tarjeta: muestran el EMAIL y el TELÉFONO
// completos y clicables. El email va primero y destacado (es el canal que
// más usa el cliente para pedir presupuesto). Se usa en toda la web.
import { EMPRESA } from '../config.mjs';
const tel = `tel:+${EMPRESA.telefonoLink}`;
const mail = `mailto:${EMPRESA.email}`;
---
<div class="ig-contactbtns">
  <a href={mail} class="ig-contact-row ig-contact-row--primary" aria-label={`Escríbenos a ${EMPRESA.email}`}>
    <span class="ig-contact-ico mail-p" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></span>
    <span class="ig-contact-txt"><span>Escríbenos</span><strong class="ig-contact-val">{EMPRESA.email}</strong></span>
  </a>
  <a href={tel} class="ig-contact-row" aria-label={`Llámanos al ${EMPRESA.telefonoMostrar}`}>
    <span class="ig-contact-ico tel" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
    <span class="ig-contact-txt"><span>Llámanos</span><strong class="ig-contact-val">{EMPRESA.telefonoMostrar}</strong></span>
  </a>
</div>
