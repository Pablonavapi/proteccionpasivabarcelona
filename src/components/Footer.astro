---
// Pie de página: datos de empresa (NAP para el SEO local), enlaces y legales.
import { EMPRESA } from '../config.mjs';
import BrandMark from './BrandMark.astro';
const anoActual = 2026;
---
<footer class="ig-footer">
  <div class="ig-footer-inner">
    <div class="ig-footer-grid">
      <div class="ig-footer-brand">
        <a href="/" class="ig-brand">
          <BrandMark />
          <span class="ig-brand-txt">
            <span class="ig-brand-name">{EMPRESA.nombre}</span>
          </span>
        </a>
        <p>Especialistas en ignifugación y protección pasiva contra incendios de estructura metálica en Barcelona y provincia. Pintura intumescente, mortero ignífugo y certificado de aplicación visado, a tiempo para tu obra.</p>
      </div>

      <div class="ig-footer-col">
        <h4>Servicios</h4>
        <ul>
          <li><a href="#servicios">Ignifugación de estructura metálica</a></li>
          <li><a href="#servicios">Pintura intumescente</a></li>
          <li><a href="#servicios">Mortero ignífugo proyectado</a></li>
          <li><a href="#servicios">Sellado cortafuegos</a></li>
          <li><a href="#servicios">Sectorización contra incendios</a></li>
          <li><a href="#normativa">Normativa (CTE / RSCIEI)</a></li>
        </ul>
      </div>

      <div class="ig-footer-col ig-footer-contact">
        <h4>Contacto</h4>
        <ul>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href={`tel:+${EMPRESA.telefonoLink}`}>{EMPRESA.telefonoMostrar}</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href={`mailto:${EMPRESA.email}`}>{EMPRESA.email}</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{EMPRESA.zonaCobertura}</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{EMPRESA.horario}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="ig-footer-bottom">
    <span>© {anoActual} {EMPRESA.nombre} · {EMPRESA.razonSocial} · CIF {EMPRESA.cif} · Empresa habilitada PCI (RIPCI) · Nº {EMPRESA.habilitacionPCI}</span>
    <span class="ig-footer-legal">
      <a href="/aviso-legal/">Aviso legal</a>
      <a href="/politica-privacidad/">Privacidad</a>
      <a href="/politica-cookies/">Cookies</a>
    </span>
  </div>
</footer>
