---
// Cabecera fija: barra de contacto (navy) + fila con logo, teléfono grande y CTAs.
import { EMPRESA } from '../config.mjs';
import BrandMark from './BrandMark.astro';
const tel = `tel:+${EMPRESA.telefonoLink}`;
const wa = `https://wa.me/${EMPRESA.whatsapp}`;
const mail = `mailto:${EMPRESA.email}`;
const showWa = !!EMPRESA.whatsapp;
---

<header class="ig-header">
  <!-- Barra superior fina con contacto (se oculta en móvil, donde aparece la barra inferior) -->
  <div class="ig-topbar">
    <div class="ig-topbar-inner">
      <div class="ig-topbar-left">
        <span class="ig-topbar-item ig-strong">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href={tel}>{EMPRESA.telefonoMostrar}</a>
        </span>
        <span class="ig-topbar-item ig-strong">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <a href={mail}>{EMPRESA.email}</a>
        </span>
      </div>
      <div class="ig-topbar-right">
        <span class="ig-topbar-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Presupuesto y visita a obra en 24-48 h
        </span>
      </div>
    </div>
  </div>

  <!-- Fila principal -->
  <div class="ig-nav">
    <a href="/" class="ig-brand" aria-label={EMPRESA.nombre}>
      <BrandMark />
      <span class="ig-brand-txt">
        <span class="ig-brand-name">{EMPRESA.nombre}</span>
        <span class="ig-brand-tag">Protección pasiva contra incendios · Barcelona</span>
      </span>
    </a>

    <div class="ig-nav-actions">
      <a href={tel} class="ig-nav-tel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="ig-nav-tel-txt">
          <span class="ig-nav-tel-lbl">Llámanos</span>
          <span class="ig-nav-tel-num">{EMPRESA.telefonoMostrar}</span>
        </span>
      </a>
      <a href={mail} class="ig-nav-tel ig-nav-mail">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span class="ig-nav-tel-txt">
          <span class="ig-nav-tel-lbl">Escríbenos</span>
          <span class="ig-nav-tel-num">{EMPRESA.email}</span>
        </span>
      </a>
    </div>
  </div>
</header>
